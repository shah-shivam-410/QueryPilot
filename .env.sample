# Sample environment variables for AI Query Agent
# Copy this file to .env and fill in the values before running the app.

DATABASE_URL=postgresql+psycopg://your_username:your_password@localhost:5432/your_db_name

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

SCHEMA_FILE=schema_Adventureworks_DB.sql
MAX_ROWS=100
STATEMENT_TIMEOUT_MS=5000
