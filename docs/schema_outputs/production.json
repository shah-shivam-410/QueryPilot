        "description": ""
      },
      {
        "name": "CONSTRAINT",
        "type": "\"CK_BillOfMaterials_EndDate\"",
        "description": ""
      },
      {
        "name": "CONSTRAINT",
        "type": "\"CK_BillOfMaterials_PerAssemblyQty\"",
        "description": ""
      },
      {
        "name": "CONSTRAINT",
        "type": "\"CK_BillOfMaterials_ProductAssemblyID\"",
        "description": ""
      }
    ]
  },
